

# Skip in CI — changesets action manages changesets on release branches
if [ -n "$CI" ] || [ -n "$GITHUB_ACTIONS" ]; then
  exit 0
fi

# Get current branch name
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Don't auto-add changesets when pushing main directly
if [ "$BRANCH" = "main" ]; then
  exit 0
fi

# Check if changesets are missing
bunx changeset status --since=origin/main >/dev/null 2>&1

if [ $? -ne 0 ]; then
  echo "🦋 Missing changeset detected before push. Auto-generating an empty changeset..."
  bunx changeset add --empty
  git add .changeset/
  git commit --no-verify -m "chore: add empty changeset before push"
  echo "✅ Empty changeset added and committed! Pushing now..."
fi
